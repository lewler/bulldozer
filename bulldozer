config = load_config()

def main(input, censor_rss, report_only=False, search_term=None, download_only=False, refresh=False, name=None, match_titles=None, after_date=None, before_date=None, threads=None, latest_episode_only=False, upload=False, upload_dry_run=False):
    """
    Main function to run the bulldozer script

    :param input: The input to the script, can be a directory path, RSS feed URL, or local RSS file path
    :param censor_rss: Whether to censor the RSS feed or not
    """
    global config
    print("· • —– ++ ---| Bulldozer v0.7.4 |--- ++ —– • ·")
    
    # Check for required dependencies at startup
    log("Checking required dependencies...", "info")
    if not check_and_install_podcast_dl():
        log("podcast-dl is not available and could not be installed automatically", "error")
        announce("podcast-dl is required but not available. Please install it manually and try again.", "error")
        exit(1)
    
    if not check_and_install_mktorrent():
        log("mktorrent is not available and could not be installed automatically", "error")
        announce("mktorrent is required but not available. Please install it manually and try again.", "error")
        exit(1)
    
    database_active = config.get("database", {}).get("active", True)
    config["_runtime"] = {
        "upload_requested": bool(upload or config.get("upload", {}).get("active", False)),
        "upload_dry_run": bool(upload_dry_run),
        "client_active": bool(config.get("client", {}).get("active", False)),
    }

    input_is_local_dir = os.path.isdir(input)
    resume_split_queue = None

    if input_is_local_dir:
        source_folder_path = Path(input)
        if not name:
            name = source_folder_path.name
        should_stage = any(
            [
                config.get("staging", {}).get("active", False),
                upload,
                upload_dry_run,
                config.get("upload", {}).get("active", False),
                config.get("client", {}).get("active", False),
            ]
        )
        staging_manager = StagingManager(config)
        if should_stage:
            resume_split_queue = load_resume_split_queue(staging_manager, source_folder_path, name, search_term, censor_rss)
        if resume_split_queue is None:
            folder_path = staging_manager.prepare(source_folder_path, display_name=name, force=should_stage)
            podcast = Podcast(
                name,
                folder_path,
                config,
                censor_rss=censor_rss,
                check_duplicates=False,
                search_term=search_term,
                source_is_local_folder=True,
            )
            new_name = fix_folder_name(name)
            if new_name != name and ask_yes_no(f"Would you like to rename the folder to {new_name}"):
                rename_folder(podcast, new_name)
                podcast.name = name = new_name
                podcast.rss.rename()
    else:
        source_rss_file = input
        output_dir = config.get("output_dir", ".")
        if not name:
            name = "unknown podcast"
            temp_dir = Path(output_dir) / 'download_temp'
        else:
            temp_dir = Path(output_dir) / f"{name}"
        if temp_dir.exists():
            if ask_yes_no(f"The directory {temp_dir} already exists. Would you like to delete it?"):
                shutil.rmtree(temp_dir)
            else:
                announce(f"Exiting. Please check {temp_dir} and remove it to continue.", "info")
                return
        temp_dir.mkdir(parents=True, exist_ok=True)
        podcast = Podcast(name, temp_dir, config, source_rss_file, censor_rss, True, search_term, match_titles, after_date, before_date, latest_episode_only)
        podcast.download_episodes(threads)
        name = podcast.name
        folder_path = temp_dir

    if download_only:
        announce(f"Podcast downloaded!", "celebrate")
        return
    split_queue = resume_split_queue
    if split_queue is None and input_is_local_dir:
        split_queue = prepare_split_queue(podcast, report_only, search_term, censor_rss)
    if split_queue is not None:
        if not split_queue:
            announce(f"All done, enjoy!", "celebrate")
            return
        if 'podcast' in locals():
            podcast.db.close()
        use_database = database_active and len(split_queue) == 1
        for split_podcast in split_queue:
            process_podcast(
                split_podcast,
                search_term=search_term,
                report_only=report_only,
                refresh=refresh,
                database_active=use_database,
                upload=upload,
                upload_dry_run=upload_dry_run,
                run_dupecheck=not report_only,
                skip_split=True,
            )
        announce(f"All done, enjoy!", "celebrate")
        return

    process_podcast(
        podcast,
        search_term=search_term,
        report_only=report_only,
        refresh=refresh,
        database_active=database_active,
        upload=upload,
        upload_dry_run=upload_dry_run,
        run_dupecheck=not report_only and input_is_local_dir,
        skip_split=False,
    )
    announce(f"All done, enjoy!", "celebrate")

def prepare_split_queue(podcast, report_only, search_term, censor_rss):
    if report_only:
        return None

    podcast.analyze_files()
    organizer = FileOrganizer(podcast, config)
    split_folder_paths = organizer.check_split()
    if not split_folder_paths or len(split_folder_paths) <= 1:
        return None
    split_mode = getattr(podcast, "split_mode", None)
    if split_mode == "yearly":
        state_path = StagingManager(config).resolve_split_state_path(
            config.get("_staging_runtime", {}).get("source_path", podcast.folder_path),
            podcast.name,
        )
        state = initialize_split_state(
            state_path,
            config.get("_staging_runtime", {}).get("source_path", podcast.folder_path),
            split_mode,
            split_folder_paths,
        )
        state = backfill_completed_folders(config, state_path, state)
        bind_runtime_split_state(config, state_path, state)
        completed_count = len((state.get("completed_folders") or {}).keys())
        if completed_count:
            announce(
                f"Found {completed_count} yearly folder(s) with existing completion state. Completed steps will default to skip unless you choose to redo them.",
                "info",
            )
        split_folder_paths = [Path(state_path).parent / folder_name for folder_name in state.get("split_folders", []) if (Path(state_path).parent / folder_name).exists()]
        if not split_folder_paths:
            return []

    split_podcasts = build_split_podcast_queue(split_folder_paths, search_term, censor_rss)
    announce(f"Prepared {len(split_podcasts)} split folders for sequential processing.", "info")
    return split_podcasts


def build_split_podcast_queue(split_folder_paths, search_term, censor_rss):
    split_podcasts = []
    for split_folder_path in split_folder_paths:
        split_folder_path = Path(split_folder_path)
        split_podcasts.append(
            Podcast(
                split_folder_path.name,
                split_folder_path,
                config,
                censor_rss=censor_rss,
                check_duplicates=False,
                search_term=search_term,
                source_is_local_folder=True,
            )
        )
    return split_podcasts


def load_resume_split_queue(staging_manager, source_folder_path, display_name, search_term, censor_rss):
    state_path = staging_manager.resolve_split_state_path(source_folder_path, display_name)
    state = load_split_state(state_path)
    if not state or state.get("split_mode") != "yearly":
        return None

    state = backfill_completed_folders(config, state_path, state)
    completed_count = len((state.get("completed_folders") or {}).keys())
    bind_runtime_split_state(config, state_path, state)
    if completed_count:
        announce(
            f"Resuming yearly split run. {completed_count} folder(s) already have completed steps recorded and will default to skip unless you choose to redo them.",
            "info",
        )
    split_folder_paths = [Path(state_path).parent / folder_name for folder_name in state.get("split_folders", []) if (Path(state_path).parent / folder_name).exists()]
    if not split_folder_paths:
        announce("No existing yearly split folders were found for the saved split state.", "warning")
        return []
    return build_split_podcast_queue(split_folder_paths, search_term, censor_rss)


def announce_existing_step_status(step_status, upload_requested=False, client_active=False):
    if not step_status.any_prior_step:
        return

    announce(f"{step_status.label_text.capitalize()} has already been processed.", "info")
    if step_status.report_exists:
        announce(f"Report for {step_status.label_text} already exists: {step_status.report_path}", "info")
    if step_status.local_torrent_exists:
        announce(f"Torrent for {step_status.label_text} has already been created: {step_status.local_torrent_path}", "info")
    if upload_requested and step_status.upload_exists:
        announce(f"{step_status.label_text.capitalize()} has already been uploaded to the tracker.", "info")
        if step_status.upload_details_url:
            announce(f"Tracker details: {step_status.upload_details_url}", "info")
    if client_active and step_status.client_present:
        announce(f"Torrent for {step_status.label_text} is already in the torrent client.", "info")
        if step_status.client_save_path:
            announce(f"Torrent client save path: {step_status.client_save_path}", "info")

def process_podcast(podcast, search_term=None, report_only=False, refresh=False, database_active=True, upload=False, upload_dry_run=False, run_dupecheck=False, skip_split=False):
    if run_dupecheck:
        podcast.check_for_duplicates()

    if database_active:
        podcast.load_from_database(refresh)

    podcast.analyze_files()

    if database_active and not podcast.analyzer.original_files:
        podcast.add_to_database(refresh)

    announce_url = config.get("announce_url", None)
    base_dir = config.get("base_dir", None)
    tracker_source = config.get("tracker_source", None)
    upload_active = config.get("upload", {}).get("active", False)
    client_active = config.get("client", {}).get("active", False)
    upload_requested = upload or upload_dry_run or upload_active
    step_status = inspect_process_resume_status(
        podcast,
        config,
        announce_url=announce_url,
        base_dir=base_dir,
        tracker_source=tracker_source,
    )
    announce_existing_step_status(step_status, upload_requested=upload_requested, client_active=client_active)

    revisit_completed_steps = False
    redo_report = False
    redo_torrent = False
    redo_upload = False
    redo_client = False
    if step_status.any_prior_step and is_interactive_terminal():
        revisit_completed_steps = ask_yes_no(
            f"Would you like to redo any completed steps for {step_status.label_text}",
            default_yes=False,
        )
    if revisit_completed_steps:
        if step_status.report_exists:
            redo_report = ask_yes_no(f"Regenerate the report for {step_status.label_text}", default_yes=False)
        if step_status.local_torrent_exists:
            redo_torrent = ask_yes_no(f"Recreate the local torrent for {step_status.label_text}", default_yes=False)
        if upload_requested and step_status.upload_exists:
            redo_upload = ask_yes_no(f"Upload {step_status.label_text} to the tracker again", default_yes=False)
        if client_active and step_status.client_present:
            redo_client = ask_yes_no(f"Reinject {step_status.label_text} into the torrent client", default_yes=False)

    fresh_processing = not step_status.any_prior_step
    if not report_only and fresh_processing:
        podcast.organize_files(skip_split=skip_split)

    report = Report(podcast, config)
    generate_report = redo_report or not step_status.report_exists
    if step_status.report_exists and not redo_report:
        log(f"Report {step_status.report_path} already exists. Skipping report generation.", "debug")

    if not podcast.metadata.has_data and generate_report:
        podcast.metadata.load(search_term)
    if not podcast.metadata.has_data and generate_report:
        announce(f"Failed to load metadata for {podcast.folder_path.name}, skipping report generation", "warning")
    elif generate_report:
        if database_active:
            podcast.add_metadata_to_database()
        report.generate()
        announce("Generated content summary:", "info")
        print("\n" + "=" * 70)

        report_path = report.get_file_path()
        if report_path and report_path.exists():
            announce(f"📄 Report: {report_path}", "info")
            log(f"Report file location: {report_path}", "info")
            try:
                with open(report_path, 'r', encoding='utf-8') as report_file:
                    report_content = report_file.read()
                    if report_content:
                        print(f"\nFull report content:")
                        print("=" * 70)
                        print(report_content)
                        print("=" * 70)
            except Exception as error:
                log(f"Could not read report file: {error}", "debug")

        image_path = podcast.image.get_file_path()
        if image_path and image_path.exists():
            announce(f"🖼️ Image: {image_path}", "info")

        announce(f"📁 Podcast folder: {podcast.folder_path}", "info")
        if hasattr(podcast, 'analyzer') and podcast.analyzer and hasattr(podcast.analyzer, 'original_files') and podcast.analyzer.original_files is not None:
            episode_count = len(podcast.analyzer.original_files)
        else:
            episode_count = 'unknown'
        announce(f"📊 Episodes: {episode_count}", "info")

        print("=" * 70 + "\n")

    if report_only:
        podcast.db.close()
        return

    if fresh_processing or generate_report:
        podcast.archive_files()

    if step_status.local_torrent_exists and not redo_torrent:
        torrent_path = step_status.local_torrent_path
    elif step_status.upload_exists and not redo_upload and step_status.tracker_torrent_path and step_status.tracker_torrent_path.exists():
        torrent_path = step_status.tracker_torrent_path
    else:
        torrent_path = create_torrent(
            podcast,
            announce_url,
            base_dir,
            tracker_source,
            replace_existing=True if redo_torrent else None,
        )

    if upload_requested:
        if not torrent_path or not Path(torrent_path).exists():
            announce("Upload requested but no torrent file is available. Create the torrent first and rerun.", "error")
        elif step_status.upload_exists and not redo_upload:
            if step_status.tracker_torrent_path and step_status.tracker_torrent_path.exists():
                announce(f"Using existing tracker torrent for {step_status.label_text}: {step_status.tracker_torrent_path}", "info")
            if client_active:
                if step_status.client_present and not redo_client:
                    log(f"Skipping client injection for {step_status.label_text}, torrent already present in client.", "debug")
                else:
                    client_torrent_path = step_status.tracker_torrent_path or torrent_path
                    if not client_torrent_path or not Path(client_torrent_path).exists():
                        announce(
                            f"{step_status.label_text.capitalize()} is already uploaded, but no tracker torrent is available for client injection. Reupload if you need a fresh tracker torrent.",
                            "warning",
                        )
                    else:
                        try:
                            client_result = ClientManager(podcast, config).run(
                                client_torrent_path,
                                prompt_default_yes=not step_status.client_present,
                            )
                        except Exception as error:
                            announce(f"Torrent client injection failed: {error}", "warning")
                            log(error, "debug")
                        else:
                            if client_result and client_result.status_message:
                                announce(client_result.status_message, "info")
                            if client_result and client_result.success:
                                mark_split_folder_client_injected(config, podcast.folder_path, client_result=client_result)
        else:
            upload_manager = UploadManager(podcast, config, torrent_path)
            try:
                upload_manager.run(dry_run=upload_dry_run)
            except Exception as error:
                announce(f"Upload failed: {error}", "error")
                log(error, "debug")
    elif client_active:
        client_torrent_path = step_status.tracker_torrent_path or torrent_path
        if step_status.client_present and not redo_client:
            log(f"Skipping client injection for {step_status.label_text}, torrent already present in client.", "debug")
        elif client_torrent_path and Path(client_torrent_path).exists():
            try:
                client_result = ClientManager(podcast, config).run(
                    client_torrent_path,
                    prompt_default_yes=not step_status.client_present,
                )
            except Exception as error:
                announce(f"Torrent client injection failed: {error}", "warning")
                log(error, "debug")
            else:
                if client_result and client_result.status_message:
                    announce(client_result.status_message, "info")
                if client_result and client_result.success:
                    mark_split_folder_client_injected(config, podcast.folder_path, client_result=client_result)

    podcast.db.close()
    move_folder = config.get("move", {}).get("active", False)
    move_folder_path = config.get("move", {}).get("path", None)
    if move_folder and move_folder_path:
        ask_to_move = config.get("move", {}).get("ask", True)
        if ask_to_move and ask_yes_no(f"Would you like to move the folder to {move_folder_path}"):
            move_folder_path = Path(move_folder_path)
            if move_folder_path.exists() and move_folder_path.is_dir():
                new_folder_path = move_folder_path / podcast.folder_path.name
                if new_folder_path.exists():
                    announce(f"Folder {new_folder_path} already exists, skipping move", "warning")
                else:
                    shutil.move(str(podcast.folder_path), str(new_folder_path))
                    announce(f"Moved folder to {new_folder_path}", "info")
            else:
                announce(f"Move folder {move_folder_path} does not exist", "error")

def check_files(input):
    """
    Check the files in the given folder

    :param input: The folder path to check
    """
    global config
    folder_path = Path(input)
    if folder_path.exists() and folder_path.is_dir():
        name = folder_path.name
        podcast = Podcast(name, folder_path, config, check_duplicates=False, source_is_local_folder=True)
        podcast.analyze_files()
        report = Report(podcast, config)
        report.generate(True)
    else:
        announce(f"Folder {folder_path} does not exist", "critical")

def create_torrent(podcast, announce_url, base_dir, tracker_source, replace_existing=None):
    """
    Create a torrent file for the given podcast

    :param podcast: The podcast object to create the torrent for
    :param announce_url: The announce URL to use for the torrent
    :param base_dir: The base directory to use for the torrent
    :param tracker_source: The source to use for the tracker
    """
    if not announce_url:
        announce(f"Skipping torrent creation for {podcast.name}, no announce URL provided", "info")
        return None
    torrent_creator = TorrentCreator(podcast, announce_url, base_dir, tracker_source)
    total_size = sum(f.stat().st_size for f in podcast.folder_path.rglob('*') if f.is_file())
    piece_size = torrent_creator.calculate_piece_size(total_size)
    runtime_config = config.get("_runtime", {})
    default_yes = any(
        [
            runtime_config.get("upload_requested", False),
            runtime_config.get("upload_dry_run", False),
            runtime_config.get("client_active", False),
        ]
    )
    if ask_yes_no(f'Would you like to create the torrent now (piece size calcualted to {piece_size})', default_yes=default_yes):
        return torrent_creator.create_torrent(piece_size, replace_existing=replace_existing)
    existing_torrent = torrent_creator.get_torrent_path()
    if existing_torrent.exists():
        return existing_torrent
    return None

def make_torrent(input):
    """
    Make a torrent file for the given folder

    :param input: The folder path to create the torrent for
    """
    global config
    folder_path = Path(input)
    if folder_path.exists() and folder_path.is_dir():
        name = folder_path.name
        podcast = Podcast(name, folder_path, config, check_duplicates=False, source_is_local_folder=True)
        announce_url = config.get("announce_url")
        base_dir = config.get("base_dir", None)
        tracker_source = config.get("tracker_source", None)
        create_torrent(podcast, announce_url, base_dir, tracker_source)
    else:
        announce(f"Folder {folder_path} does not exist", "error")
        return
    announce(f"All done, enjoy!", "celebrate")

def dupecheck(input):
    """
    Perform a dupecheck on the given input

    :param input: The name to dupecheck
    """
    dupecheck = config.get("dupecheck", False)
    if not dupecheck:
        announce("Dupecheck is not enabled in the config", "info")
        return
    api_key = config.get("api_key")
    dupecheck_url = config.get("dupecheck_url")
    
    dupe_checker = DupeChecker(input, dupecheck_url, api_key, False)
    dupe_checker.check_duplicates(True)

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Podcast Automator Script")
    parser.add_argument("input", nargs="?", help="RSS feed URL, directory path, local RSS file path, or name to dupecheck")
    parser.add_argument("--censor-rss", action="store_true", help="Make sure the RSS feed is censored")
    parser.add_argument("--report-only", action="store_true", help="Generates a report only")
    parser.add_argument("--download-only", action="store_true", help="Only download the files")
    parser.add_argument("--refresh", action="store_true", help="Don't read data from the database")
    parser.add_argument("--check-files", action="store_true", help="Only check the files")
    parser.add_argument("--dupecheck", action="store_true", help="Perform a dupecheck")
    parser.add_argument("--make-torrent", action="store_true", help="Only make a torrent file")
    parser.add_argument("--check-config", action="store_true", help="Check that user config is valid")
    parser.add_argument("--log-level", type=str, help="Set the logging level (e.g., DEBUG, INFO, WARNING, ERROR, CRITICAL)")
    parser.add_argument("--search-term", type=str, help="Search term to use when querying APIs")
    parser.add_argument("--name", type=str, help="Override the name to use for the podcast")
    parser.add_argument("--match-titles", type=str, help="Only includes the episodes with titles matching the given string")
    parser.add_argument("--after", type=str, help="Only include episodes published after this date (YYYY-MM-DD format)")
    parser.add_argument("--before", type=str, help="Only include episodes published before this date (YYYY-MM-DD format)")
    parser.add_argument("--threads", type=int, help="Number of threads to use for podcast-dl downloading (overrides config setting)")
    parser.add_argument("--latest-episode-only", action="store_true", help="Only download the latest episode")
    parser.add_argument("--upload", action="store_true", help="Run the configured upload backend after torrent creation")
    parser.add_argument("--upload-dry-run", action="store_true", help="Validate upload auth, form data, and assets without submitting")
    args = parser.parse_args()

    if not config:
        exit(1)

    setup_logging(args.log_level, config)

    if not args.check_config and not args.input:
        parser.error("the 'input' argument is required unless '--check-config' is specified")

    if args.make_torrent:
        make_torrent(args.input)
    elif args.dupecheck:
        dupecheck(args.input)
    elif args.check_files:
        check_files(args.input)
    elif args.check_config:
        check_config()
    else:
        main(
            args.input,
            args.censor_rss,
            args.report_only,
            args.search_term,
            args.download_only,
            args.refresh,
            args.name,
            args.match_titles,
            args.after,
            args.before,
            args.threads,
            args.latest_episode_only,
            args.upload,
            args.upload_dry_run,
        )
